{
  "@context": "https://uor.foundation/contexts/uor-v1.jsonld",
  "@type": "uor:SystemManifest",
  "@id": "urn:uor:hologram:manifest:1.0.0",
  "name": "hologram",
  "version": "1.0.0",
  "description": "Hologram OS — browser-native operating system structured as a 1:1 mirror of the Linux kernel. Projects and executes digital systems via content-addressed algebraic identity, lens morphisms, and coherence-priority scheduling.",
  "uor:specification": "1.0.0",
  "uor:canonicalHash": "sha256:pending-genesis",

  "layers": {
    "firmware": {
      "path": "genesis/",
      "description": "Mathematical axioms (≡ BIOS/UEFI ROM). 8 axioms fused to kernel identity: ring, hash, CID, codec, mirror, signal, POST, constitution.",
      "status": "maintained"
    },
    "kernel": {
      "path": "kernel/",
      "description": "Q-Kernel source tree (≡ /usr/src/linux/). 20 subsystems mirroring Linux kernel directories.",
      "subsystems": [
        "init", "kernel", "mm", "fs", "block", "drivers",
        "net", "ipc", "crypto", "arch", "security",
        "lib", "include", "certs", "samples", "scripts",
        "tools", "Documentation", "agents", "surface"
      ],
      "entrypoint": "kernel/index.ts",
      "status": "maintained"
    },
    "platform": {
      "path": "platform/",
      "description": "Hardware Abstraction Layer (≡ HAL/BSP). Single bridge.ts file handles ALL external I/O.",
      "gateway": "platform/bridge.ts",
      "status": "maintained"
    },
    "userspace": {
      "path": "usr/",
      "description": "User space (≡ /usr/). Shell, notebook, ceremony UI, hooks, shared components.",
      "directories": {
        "bin": "User programs (shell, notebook, ceremony)",
        "lib": "Shared libraries (hooks, UI components)"
      },
      "status": "maintained"
    }
  },

  "uor:namespaces": [
    "u:", "schema:", "op:", "proof:", "partition:", "cert:",
    "derivation:", "morphism:", "store:", "state:", "trace:",
    "observable:", "tsp:", "fpp:", "trqp:", "polytree:",
    "kernel:", "hologram:", "lens:", "projection:", "compute:",
    "tee:"
  ],

  "routes": [
    "/hologram",
    "/hologram-os",
    "/hologram-ui",
    "/hologram-console",
    "/hologram-compute",
    "/hologram-install"
  ],
  "routeVisibility": "private",

  "dependencies": {
    "ring-core": "^1.0.0",
    "identity": "^1.0.0",
    "derivation": "^1.0.0",
    "resolver": "^1.0.0",
    "self-verify": "^1.0.0",
    "uns": "^1.0.0",
    "uor-sdk": "^1.0.0",
    "kg-store": "^1.0.0",
    "jsonld": "^1.0.0",
    "triad": "^1.0.0",
    "trace": "^1.0.0",
    "atlas": "^1.0.0",
    "observable": "^1.0.0"
  },

  "externalDependencies": {
    "@noble/post-quantum": "^0.5.4",
    "@huggingface/transformers": "^3.8.1",
    "@webgpu/types": "^0.1.69",
    "fflate": "^0.8.2",
    "hls.js": "^1.6.15",
    "d3-force": "^3.0.0",
    "framer-motion": "^12.34.3"
  },

  "storage": {
    "tables": [
      "hologram_sessions",
      "user_data_bank",
      "agent_memories",
      "agent_session_chains",
      "agent_relationships",
      "agent_compression_witnesses"
    ],
    "buckets": []
  },

  "exportGate": {
    "description": "CID-addressed export gate for dehydrating and shipping complete Hologram snapshots.",
    "format": "dag-json",
    "includes": [
      "manifest.json",
      "genesis/**",
      "kernel/**",
      "platform/**",
      "usr/**"
    ],
    "excludes": [
      "**/*.test.ts",
      "**/*.spec.ts",
      "node_modules/**"
    ],
    "checksumAlgorithm": "sha-256"
  },

  "assets": []
}