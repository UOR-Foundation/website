{
  "@context": "https://uor.foundation/contexts/uor-v1.jsonld",
  "@type": "uor:Module",
  "name": "uor-sdk",
  "version": "1.0.0",
  "description": "Typed TypeScript bridge to the live UOR REST API. Trust anchor for all app-platform modules.",
  "uor:specification": "1.0.0",
  "uor:namespaces": [
    "u:", "schema:", "op:", "kernel:",
    "partition:", "trace:", "observable:",
    "derivation:", "cert:", "morphism:",
    "store:", "proof:", "state:"
  ],
  "exports": [
    "createUorClient",
    "UorApiError",
    "neg", "bnot", "succ",
    "verifyCriticalIdentity",
    "singleProofHash",
    "computeModuleIdentity"
  ],
  "dependencies": {
    "core": "^1.0.0"
  },
  "routes": [],
  "api_endpoints": [
    "/kernel/op/verify",
    "/kernel/op/compute",
    "/kernel/address/encode",
    "/bridge/partition",
    "/bridge/trace",
    "/store/write",
    "/store/read/:cid",
    "/store/verify/:cid"
  ],
  "assets": []
}
